# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-level-token   # required for Socket Mode (recommended)
SLACK_BOT_USER_ID=                           # optional: auto-fetched on first run

# Monday.com API token
MONDAY_API_TOKEN=your-monday-api-token

# Bugs Queue board (Bugs → Dev Bugs Queue group)
MONDAY_BUGS_BOARD_ID=                        # numeric board ID from URL
MONDAY_BUGS_GROUP_ID=                        # run inspect_board.py to find this
MONDAY_BUGS_REPORTER_COL=                    # run inspect_board.py to find this

# Enhancements board (Enhancements + Features → Incoming Enhancements group)
MONDAY_ENHANCEMENTS_BOARD_ID=                # numeric board ID from URL
MONDAY_ENHANCEMENTS_GROUP_ID=                # run inspect_board.py to find this
MONDAY_ENH_REPORTER_COL=                     # run inspect_board.py to find this

# Your Monday user ID (run inspect_board.py → printed under "Your Monday user")
MONDAY_REPORTER_ID=

# Port for HTTP mode (ignored when using Socket Mode)
PORT=3000
