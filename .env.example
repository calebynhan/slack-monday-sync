# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_BOT_USER_ID=U0123456789   # bot's own user ID (find via /auth.test)

# Monday.com
MONDAY_API_TOKEN=your-monday-api-token
MONDAY_BOARD_ID=1234567890       # the board to create items on

# Optional: column IDs in your Monday board
# Leave blank to skip setting that column
MONDAY_STATUS_COLUMN_ID=status   # column ID for Bug/Enhancement/Feature label
MONDAY_TEXT_COLUMN_ID=           # column ID for a long-text / notes column (optional)

# Port (default 3000)
PORT=3000
