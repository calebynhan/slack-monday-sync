# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-level-token   # required for Socket Mode (recommended)
SLACK_BOT_USER_ID=                           # optional: auto-fetched on first run

# Monday.com
MONDAY_API_TOKEN=your-monday-api-token
MONDAY_BOARD_ID=1234567890                   # numeric board ID from the URL

# Optional: column IDs in your Monday board
# Run `python inspect_board.py` to list all column IDs for your board.
# Leave blank to skip setting that column.
MONDAY_STATUS_COLUMN_ID=                     # column for Bug/Enhancement/Feature label
MONDAY_TEXT_COLUMN_ID=                       # column for long-text notes (optional)

# Port for HTTP mode (ignored when using Socket Mode)
PORT=3000
